---
import Layout from '../../../layouts/Layout.astro';
import { LANGUAGES, t, type Lang } from '../../../i18n/translations';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../../utils/paths';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  const enProjects = allProjects.filter(e => e.id.startsWith('en/'));

  return LANGUAGES.flatMap(lang =>
    enProjects.map(p => ({
      params: { lang, id: p.data.id },
    }))
  );
}

const { lang, id } = Astro.params as { lang: Lang; id: string };
const tr = t(lang);

const allProjects = await getCollection('projects');
const langEntry = allProjects.find(e => e.id.startsWith(`${lang}/`) && e.data.id === id);
const enEntry = allProjects.find(e => e.id.startsWith('en/') && e.data.id === id)!;

const entry = (langEntry && langEntry.body?.trim()) ? langEntry : enEntry;
const { Content } = await render(entry);
---

<Layout lang={lang} title={entry.data.title}>
  <article class="max-w-3xl mx-auto px-6 pt-20 pb-24">

    <!-- Back link -->
    <div class="mb-16 fade-up">
      <a href={withBase(`/${lang}/projects`)}
         class="group inline-flex items-center gap-2 text-xs tracking-[0.2em] uppercase no-underline text-[var(--color-muted)] transition-colors duration-200 hover:text-[var(--color-text)]">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300 group-hover:-translate-x-1">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        {tr.projects.title}
      </a>
    </div>

    <!-- Header -->
    <header class="mb-16 fade-up fade-up-delay-1">
      <div class="flex items-baseline gap-4 mb-6 flex-wrap">
        <h1 class="font-display text-[clamp(2rem,8vw,3.5rem)] font-medium leading-tight text-[var(--color-text)]">
          {entry.data.title}
        </h1>
        {entry.data.wip && (
          <span class="text-[10px] px-2 py-0.5 tracking-widest uppercase border border-[var(--color-accent)] text-[var(--color-accent)] self-center">
            {tr.projects.wip}
          </span>
        )}
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-8">
        {entry.data.tags.map(tag => (
          <span class="text-[10px] px-2 py-0.5 tracking-[0.15em] uppercase bg-[var(--color-border)] text-[var(--color-muted)]">
            {tag}
          </span>
        ))}
      </div>

      <!-- Links -->
      {(entry.data.demo || entry.data.repo) && (
        <div class="flex items-center gap-8 border-y border-[var(--color-border)] py-6">
          {entry.data.demo && (
            <a href={entry.data.demo}
               target="_blank"
               rel="noopener noreferrer"
               class="group inline-flex items-center gap-1.5 text-xs tracking-[0.15em] uppercase no-underline text-[var(--color-muted)] transition-colors duration-200 hover:text-[var(--color-accent)]">
              {tr.projects.demo}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                <path d="M7 17L17 7M7 7h10v10"/>
              </svg>
            </a>
          )}
          {entry.data.repo && (
            <a href={entry.data.repo}
               target="_blank"
               rel="noopener noreferrer"
               class="group inline-flex items-center gap-1.5 text-xs tracking-[0.15em] uppercase no-underline text-[var(--color-muted)] transition-colors duration-200 hover:text-[var(--color-accent)]">
              {tr.projects.code}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                <path d="M7 17L17 7M7 7h10v10"/>
              </svg>
            </a>
          )}
        </div>
      )}
    </header>

    <!-- Markdown body -->
    <div class="prose-project fade-up fade-up-delay-2">
      <Content />
    </div>

  </article>
</Layout>

