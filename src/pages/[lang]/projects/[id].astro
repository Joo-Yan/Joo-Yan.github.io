---
import Layout from '../../../layouts/Layout.astro';
import { LANGUAGES, t, type Lang } from '../../../i18n/translations';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../../utils/paths';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  const enProjects = allProjects.filter(e => e.id.startsWith('en/'));

  return LANGUAGES.flatMap(lang =>
    enProjects.map(p => ({
      params: { lang, id: p.data.id },
    }))
  );
}

const { lang, id } = Astro.params as { lang: Lang; id: string };
const tr = t(lang);

const allProjects = await getCollection('projects');
const langEntry = allProjects.find(e => e.id.startsWith(`${lang}/`) && e.data.id === id);
const enEntry = allProjects.find(e => e.id.startsWith('en/') && e.data.id === id)!;

const entry = (langEntry && langEntry.body?.trim()) ? langEntry : enEntry;
const { Content } = await render(entry);
---

<Layout lang={lang} title={entry.data.title}>
  <article class="max-w-3xl mx-auto px-6 pt-16 pb-24">

    <!-- Back link -->
    <div class="mb-12">
      <a href={withBase(`/${lang}/projects`)}
         class="text-xs tracking-widest uppercase transition-colors duration-200"
         style="color: var(--color-muted); text-decoration: none;"
         onmouseover="this.style.color='var(--color-text)'"
         onmouseout="this.style.color='var(--color-muted)'">
        ← {tr.projects.title}
      </a>
    </div>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-start gap-4 mb-4 flex-wrap">
        <h1 class="font-serif text-4xl md:text-5xl font-light" style="color: var(--color-text);">
          {entry.data.title}
        </h1>
        {entry.data.wip && (
          <span class="text-xs px-2 py-1 tracking-wider self-center"
                style="border: 1px solid var(--color-accent); color: var(--color-accent);">
            {tr.projects.wip}
          </span>
        )}
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-6">
        {entry.data.tags.map(tag => (
          <span class="text-xs px-2 py-1 tracking-wider"
                style="background-color: var(--color-border); color: var(--color-muted);">
            {tag}
          </span>
        ))}
      </div>

      <!-- Links -->
      {(entry.data.demo || entry.data.repo) && (
        <div class="flex items-center gap-6">
          {entry.data.demo && (
            <a href={entry.data.demo}
               target="_blank"
               rel="noopener noreferrer"
               class="text-sm tracking-widest uppercase transition-colors duration-200"
               style="color: var(--color-muted); text-decoration: none;"
               onmouseover="this.style.color='var(--color-text)'"
               onmouseout="this.style.color='var(--color-muted)'">
              {tr.projects.demo} ↗
            </a>
          )}
          {entry.data.repo && (
            <a href={entry.data.repo}
               target="_blank"
               rel="noopener noreferrer"
               class="text-sm tracking-widest uppercase transition-colors duration-200"
               style="color: var(--color-muted); text-decoration: none;"
               onmouseover="this.style.color='var(--color-text)'"
               onmouseout="this.style.color='var(--color-muted)'">
              {tr.projects.code} ↗
            </a>
          )}
        </div>
      )}

      <div class="mt-8" style="width: 3rem; height: 1px; background-color: var(--color-accent);"></div>
    </header>

    <!-- Markdown body -->
    <div class="prose-project">
      <Content />
    </div>

  </article>
</Layout>
