---
import Layout from '../../layouts/Layout.astro';
import { LANGUAGES, t, type Lang } from '../../i18n/translations';
import { aboutText } from '../../i18n/content';

export function getStaticPaths() {
  return LANGUAGES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = t(lang);
const paragraphs = aboutText[lang];
---

<Layout lang={lang} title={tr.about.title}>
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-24">

    <!-- Page heading -->
    <div class="mb-16">
      <h1 class="font-serif text-5xl font-light" style="color: var(--color-text);">
        {tr.about.title}
      </h1>
      <div class="mt-4" style="width: 3rem; height: 1px; background-color: var(--color-accent);"></div>
    </div>

    <!-- Cover letter text -->
    <div class="max-w-2xl space-y-8">
      {paragraphs.map(para => (
        <p class="font-serif text-xl font-light leading-relaxed"
           style="color: var(--color-text); letter-spacing: 0.01em;">
          {para}
        </p>
      ))}
    </div>

    <!-- Contact CTA -->
    <div class="mt-16 pt-10" style="border-top: 1px solid var(--color-border);">
      <a href="mailto:zhuoyanyuu@gmail.com"
         class="text-sm tracking-wider transition-colors duration-200"
         style="color: var(--color-accent); text-decoration: none;"
         onmouseover="this.style.color='var(--color-text)'"
         onmouseout="this.style.color='var(--color-accent)'">
        zhuoyanyuu@gmail.com ↗
      </a>
    </div>
  </section>
</Layout>
