---
import Layout from '../../layouts/Layout.astro';
import { LANGUAGES, t, type Lang } from '../../i18n/translations';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return LANGUAGES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = t(lang);

const aboutEntries = await getCollection('about');
const entry = aboutEntries.find(e => e.id === lang)
           ?? aboutEntries.find(e => e.id === 'en');

const isEmpty = !entry?.body?.trim();
const paragraphs = isEmpty ? [] : entry!.body!.trim().split(/\n\n+/);
---

<Layout lang={lang} title={tr.about.title}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pt-10 sm:pt-16 pb-16 sm:pb-24">

    <!-- Page heading -->
    <div class="mb-10 sm:mb-16">
      <h1 class="font-serif text-3xl sm:text-5xl font-light" style="color: var(--color-text);">
        {tr.about.title}
      </h1>
      <div class="mt-4" style="width: 3rem; height: 1px; background-color: var(--color-accent);"></div>
    </div>

    <!-- Cover letter text -->
    <div class="max-w-2xl prose-about">
      {isEmpty ? (
        <p style="font-family: ui-serif, Georgia, serif; font-size: 1.25rem; font-weight: 300; color: var(--color-muted);">
          暂无中文版
        </p>
      ) : (
        paragraphs.map(para => (
          <p>{para}</p>
        ))
      )}
    </div>

    <!-- Contact CTA -->
    <div class="mt-16 pt-10" style="border-top: 1px solid var(--color-border);">
      <a href="mailto:zhuoyanyuu@gmail.com"
         class="text-sm tracking-wider transition-colors duration-200"
         style="color: var(--color-accent); text-decoration: none;"
         onmouseover="this.style.color='var(--color-text)'"
         onmouseout="this.style.color='var(--color-accent)'">
        zhuoyanyuu@gmail.com ↗
      </a>
    </div>
  </section>
</Layout>
