---
import Layout from '../../layouts/Layout.astro';
import { LANGUAGES, t, type Lang } from '../../i18n/translations';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return LANGUAGES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = t(lang);

const aboutEntries = await getCollection('about');
const entry = aboutEntries.find(e => e.id === lang)
           ?? aboutEntries.find(e => e.id === 'en');

const isEmpty = !entry?.body?.trim();
const paragraphs = isEmpty ? [] : entry!.body!.trim().split(/\n\n+/);
---

<Layout lang={lang} title={tr.about.title}>
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-24">

    <!-- Page heading -->
    <div class="mb-20 fade-up">
      <h1 class="font-display text-[clamp(2.5rem,10vw,4.5rem)] font-medium leading-tight text-[var(--color-text)]">
        {tr.about.title}
      </h1>
    </div>

    <!-- Content -->
    <div class="max-w-2xl prose-about fade-up fade-up-delay-1">
      {isEmpty ? (
        <p class="font-serif text-xl font-light text-[var(--color-muted)] italic">
          Coming soon.
        </p>
      ) : (
        paragraphs.map(para => (
          <p>{para}</p>
        ))
      )}
    </div>

    <!-- Contact CTA -->
    <div class="mt-20 pt-10 border-t border-[var(--color-border)] fade-up fade-up-delay-2">
      <a href="mailto:zhuoyanyuu@gmail.com"
         class="group inline-flex items-center gap-2 text-sm tracking-[0.15em] uppercase no-underline text-[var(--color-accent)] font-medium transition-colors duration-200 hover:text-[var(--color-text)]">
        zhuoyanyuu@gmail.com
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1">
          <path d="M7 17L17 7M7 7h10v10"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>

