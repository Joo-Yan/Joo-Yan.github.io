---
import Layout from '../../../layouts/Layout.astro';
import { LANGUAGES, t, type Lang } from '../../../i18n/translations';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../../utils/paths';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog').catch(() => []);
  const enPosts = allPosts.filter(e => e.id.startsWith('en/'));

  return LANGUAGES.flatMap(lang =>
    enPosts.map(p => ({
      params: { lang, slug: p.id.replace('en/', '') },
    }))
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const tr = t(lang);

const allPosts = await getCollection('blog');
const langEntry = allPosts.find(e => e.id === `${lang}/${slug}`);
const enEntry = allPosts.find(e => e.id === `en/${slug}`)!;

const entry = (langEntry && langEntry.body?.trim()) ? langEntry : enEntry;
const { Content } = await render(entry);
---

<Layout lang={lang} title={entry.data.title}>
  <article class="max-w-3xl mx-auto px-6 pt-20 pb-24">

    <!-- Back link -->
    <div class="mb-16 fade-up">
      <a href={withBase(`/${lang}/blog`)}
         class="group inline-flex items-center gap-2 text-xs tracking-[0.2em] uppercase no-underline text-[var(--color-muted)] transition-colors duration-200 hover:text-[var(--color-text)]">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300 group-hover:-translate-x-1">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        {tr.blog.title}
      </a>
    </div>

    <!-- Header -->
    <header class="mb-16 fade-up fade-up-delay-1">
      <h1 class="font-display text-[clamp(2rem,8vw,3.5rem)] font-medium leading-tight text-[var(--color-text)] mb-6">
        {entry.data.title}
      </h1>

      <div class="flex items-center justify-between border-y border-[var(--color-border)] py-6">
        <p class="text-[10px] tracking-[0.15em] uppercase text-[var(--color-muted)] font-sans">
          {entry.data.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : lang === 'fr' ? 'fr-FR' : 'en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>

        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {entry.data.tags.map(tag => (
              <span class="text-[10px] px-2 py-0.5 tracking-[0.1em] uppercase bg-[var(--color-border)] text-[var(--color-muted)]">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Markdown body -->
    <div class="prose-blog fade-up fade-up-delay-2">
      <Content />
    </div>

  </article>
</Layout>

