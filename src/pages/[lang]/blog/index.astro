---
import Layout from '../../../layouts/Layout.astro';
import { LANGUAGES, t, type Lang } from '../../../i18n/translations';
import { getCollection } from 'astro:content';
import { withBase } from '../../../utils/paths';

export async function getStaticPaths() {
  return LANGUAGES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = t(lang);

const allPosts = await getCollection('blog').catch(() => []);
const enPosts = allPosts
  .filter(e => e.id.startsWith('en/'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const hasPosts = enPosts.length > 0;
---

<Layout lang={lang} title={tr.blog.title}>
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-24">

    <!-- Page heading -->
    <div class="mb-20 fade-up">
      <h1 class="font-display text-[clamp(2.5rem,10vw,4.5rem)] font-medium leading-tight text-[var(--color-text)]">
        {tr.blog.title}
      </h1>
    </div>

    {hasPosts ? (
      <div class="space-y-12">
        {enPosts.map((post, i) => {
          const slug = post.id.replace('en/', '');
          const langPost = allPosts.find(e => e.id === `${lang}/${slug}` && e.body?.trim());
          const display = langPost ?? post;
          return (
            <article class="fade-up pt-10 border-t border-[var(--color-border)] group" style={`animation-delay: ${0.1 * (i + 1)}s`}>
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-4">
                <a href={withBase(`/${lang}/blog/${slug}`)}
                   class="font-display text-[clamp(1.25rem,4vw,2rem)] font-medium text-[var(--color-text)] no-underline transition-colors duration-300 hover:text-[var(--color-accent)]">
                  {display.data.title}
                </a>
                <p class="text-[10px] tracking-[0.15em] uppercase text-[var(--color-muted)] font-sans">
                  {display.data.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : lang === 'fr' ? 'fr-FR' : 'en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
                </p>
              </div>
              {display.data.description && (
                <p class="text-[clamp(1rem,3vw,1.125rem)] leading-relaxed text-[var(--color-muted)] font-serif italic max-w-2xl">
                  {display.data.description}
                </p>
              )}
            </article>
          );
        })}
      </div>
    ) : (
      <div class="max-w-md fade-up">
        <p class="font-display text-[clamp(1.5rem,5vw,2.5rem)] font-medium mb-6 text-[var(--color-muted)]">
          {tr.blog.comingSoon}
        </p>
        <p class="text-lg leading-relaxed text-[var(--color-muted)] font-serif italic">
          {tr.blog.comingSoonText}
        </p>
      </div>
    )}
  </section>
</Layout>

