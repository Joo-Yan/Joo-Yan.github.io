---
import Layout from '../../layouts/Layout.astro';
import { LANGUAGES, t, type Lang } from '../../i18n/translations';
import { projects } from '../../i18n/content';

export function getStaticPaths() {
  return LANGUAGES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = t(lang);
---

<Layout lang={lang} title={tr.projects.title}>
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-24">

    <!-- Page heading -->
    <div class="mb-16">
      <h1 class="font-serif text-5xl font-light" style="color: var(--color-text);">
        {tr.projects.title}
      </h1>
      <div class="mt-4" style="width: 3rem; height: 1px; background-color: var(--color-accent);"></div>
    </div>

    <!-- Project cards -->
    <div class="space-y-12">
      {projects.map(project => (
        <article style="border-top: 1px solid var(--color-border); padding-top: 2.5rem;">
          <div class="flex items-start justify-between gap-4 mb-4">
            <div class="flex items-center gap-3">
              <h2 class="font-serif text-2xl font-light" style="color: var(--color-text);">
                {project.title[lang]}
              </h2>
              {project.wip && (
                <span class="text-xs px-2 py-0.5 tracking-wider shrink-0"
                      style="border: 1px solid var(--color-accent); color: var(--color-accent);">
                  {tr.projects.wip}
                </span>
              )}
            </div>
            <!-- Links -->
            <div class="flex items-center gap-4 shrink-0">
              {project.demo && (
                <a href={project.demo}
                   target="_blank"
                   rel="noopener noreferrer"
                   class="text-xs tracking-widest uppercase transition-colors duration-200"
                   style="color: var(--color-accent); text-decoration: none;"
                   onmouseover="this.style.color='var(--color-text)'"
                   onmouseout="this.style.color='var(--color-accent)'">
                  {tr.projects.demo} ↗
                </a>
              )}
              {project.repo && (
                <a href={project.repo}
                   target="_blank"
                   rel="noopener noreferrer"
                   class="text-xs tracking-widest uppercase transition-colors duration-200"
                   style="color: var(--color-muted); text-decoration: none;"
                   onmouseover="this.style.color='var(--color-text)'"
                   onmouseout="this.style.color='var(--color-muted)'">
                  {tr.projects.code} ↗
                </a>
              )}
            </div>
          </div>

          <p class="text-base leading-relaxed mb-6 max-w-2xl"
             style="color: var(--color-muted);">
            {project.description[lang]}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {project.tags.map(tag => (
              <span class="text-xs px-2 py-1 tracking-wider"
                    style="background-color: var(--color-border); color: var(--color-muted);">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
