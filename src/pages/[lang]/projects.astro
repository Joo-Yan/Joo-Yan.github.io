---
import Layout from '../../layouts/Layout.astro';
import { LANGUAGES, t, type Lang } from '../../i18n/translations';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/paths';

export async function getStaticPaths() {
  return LANGUAGES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = t(lang);

const allProjects = await getCollection('projects');
const enProjects = allProjects
  .filter(e => e.id.startsWith('en/'))
  .sort((a, b) => a.data.order - b.data.order);

// For each EN project, use the lang version if it has real content, else fall back to EN
const projects = enProjects.map(enEntry => {
  const projectId = enEntry.id.replace('en/', '');
  const langEntry = allProjects.find(e => e.id === `${lang}/${projectId}`);
  return (langEntry && langEntry.body?.trim()) ? langEntry : enEntry;
});
---

<Layout lang={lang} title={tr.projects.title}>
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-24">

    <!-- Page heading -->
    <div class="mb-16">
      <h1 class="font-serif text-5xl font-light" style="color: var(--color-text);">
        {tr.projects.title}
      </h1>
      <div class="mt-4" style="width: 3rem; height: 1px; background-color: var(--color-accent);"></div>
    </div>

    <!-- Project cards -->
    <div class="space-y-12">
      {projects.map(project => (
        <article style="border-top: 1px solid var(--color-border); padding-top: 2.5rem;">
          <div class="flex items-start justify-between gap-4 mb-4">
            <div class="flex items-center gap-3">
              <a href={withBase(`/${lang}/projects/${project.data.id}`)}
                 class="font-serif text-2xl font-light transition-colors duration-200"
                 style="color: var(--color-text); text-decoration: none;"
                 onmouseover="this.style.color='var(--color-accent)'"
                 onmouseout="this.style.color='var(--color-text)'">
                {project.data.title}
              </a>
              {project.data.wip && (
                <span class="text-xs px-2 py-0.5 tracking-wider shrink-0"
                      style="border: 1px solid var(--color-accent); color: var(--color-accent);">
                  {tr.projects.wip}
                </span>
              )}
            </div>
            <!-- Links -->
            <div class="flex items-center gap-4 shrink-0">
              {project.data.demo && (
                <a href={project.data.demo}
                   target="_blank"
                   rel="noopener noreferrer"
                   class="text-xs tracking-widest uppercase transition-colors duration-200"
                   style="color: var(--color-muted); text-decoration: none;"
                   onmouseover="this.style.color='var(--color-text)'"
                   onmouseout="this.style.color='var(--color-muted)'">
                  {tr.projects.demo} ↗
                </a>
              )}
              {project.data.repo && (
                <a href={project.data.repo}
                   target="_blank"
                   rel="noopener noreferrer"
                   class="text-xs tracking-widest uppercase transition-colors duration-200"
                   style="color: var(--color-muted); text-decoration: none;"
                   onmouseover="this.style.color='var(--color-text)'"
                   onmouseout="this.style.color='var(--color-muted)'">
                  {tr.projects.code} ↗
                </a>
              )}
            </div>
          </div>

          <p class="text-base leading-relaxed mb-6 max-w-2xl"
             style="color: var(--color-muted);">
            {project.data.description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {project.data.tags.map(tag => (
              <span class="text-xs px-2 py-1 tracking-wider"
                    style="background-color: var(--color-border); color: var(--color-muted);">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
