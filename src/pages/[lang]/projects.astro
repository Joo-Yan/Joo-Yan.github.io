---
import Layout from '../../layouts/Layout.astro';
import { LANGUAGES, t, type Lang } from '../../i18n/translations';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/paths';

export async function getStaticPaths() {
  return LANGUAGES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const tr = t(lang);

const allProjects = await getCollection('projects');
const enProjects = allProjects
  .filter(e => e.id.startsWith('en/'))
  .sort((a, b) => a.data.order - b.data.order);

// For each EN project, use the lang version if it has real content, else fall back to EN
const projects = enProjects.map(enEntry => {
  const projectId = enEntry.id.replace('en/', '');
  const langEntry = allProjects.find(e => e.id === `${lang}/${projectId}`);
  return (langEntry && langEntry.body?.trim()) ? langEntry : enEntry;
});
---

<Layout lang={lang} title={tr.projects.title}>
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-24">

    <!-- Page heading -->
    <div class="mb-20 fade-up">
      <h1 class="font-display text-[clamp(2.5rem,10vw,4.5rem)] font-medium leading-tight text-[var(--color-text)]">
        {tr.projects.title}
      </h1>
    </div>

    <!-- Project list -->
    <div class="space-y-16">
      {projects.map((project, i) => (
        <article class={`fade-up pt-12 border-t border-[var(--color-border)]`} style={`animation-delay: ${0.1 * (i + 1)}s`}>
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
            <div class="flex flex-wrap items-center gap-4">
              <a href={withBase(`/${lang}/projects/${project.data.id}`)}
                 class="font-display text-[clamp(1.5rem,5vw,2.25rem)] font-medium text-[var(--color-text)] no-underline transition-colors duration-300 hover:text-[var(--color-accent)]">
                {project.data.title}
              </a>
              {project.data.wip && (
                <span class="text-[10px] px-2 py-0.5 tracking-widest uppercase border border-[var(--color-accent)] text-[var(--color-accent)]">
                  {tr.projects.wip}
                </span>
              )}
            </div>

            <!-- Links -->
            <div class="flex items-center gap-6 shrink-0 pt-2">
              {project.data.demo && (
                <a href={project.data.demo}
                   target="_blank"
                   rel="noopener noreferrer"
                   class="group inline-flex items-center gap-1.5 text-xs tracking-[0.15em] uppercase no-underline text-[var(--color-muted)] transition-colors duration-200 hover:text-[var(--color-text)]">
                  {tr.projects.demo}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                    <path d="M7 17L17 7M7 7h10v10"/>
                  </svg>
                </a>
              )}
              {project.data.repo && (
                <a href={project.data.repo}
                   target="_blank"
                   rel="noopener noreferrer"
                   class="group inline-flex items-center gap-1.5 text-xs tracking-[0.15em] uppercase no-underline text-[var(--color-muted)] transition-colors duration-200 hover:text-[var(--color-text)]">
                  {tr.projects.code}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                    <path d="M7 17L17 7M7 7h10v10"/>
                  </svg>
                </a>
              )}
            </div>
          </div>

          <p class="text-lg leading-relaxed text-[var(--color-muted)] font-serif italic mb-8 max-w-2xl">
            {project.data.description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {project.data.tags.map(tag => (
              <span class="text-[10px] px-2 py-0.5 tracking-[0.15em] uppercase bg-[var(--color-border)] text-[var(--color-muted)]">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

