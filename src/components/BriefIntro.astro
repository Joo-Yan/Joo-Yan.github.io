---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<section class="max-w-4xl mx-auto px-6 py-16"
         style="border-top: 1px solid var(--color-border);">
  <p class="text-xl md:text-2xl font-light leading-relaxed max-w-2xl"
     style="color: var(--color-text); font-family: var(--font-serif); letter-spacing: 0.01em;">
    {tr.brief.text}
  </p>
</section>
