---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<section class="max-w-4xl mx-auto px-6 py-16 sm:py-24 border-t border-[var(--color-border)]">
  <div class="max-w-2xl">
    {tr.brief.paragraphs.map((para) => (
      <p class="text-[clamp(1.125rem,4vw,1.375rem)] font-serif font-normal leading-relaxed text-[var(--color-text)] mb-8 last:mb-0">
        {para}
      </p>
    ))}
  </div>
</section>
