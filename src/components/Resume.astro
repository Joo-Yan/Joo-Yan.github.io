---
import { t, type Lang } from '../i18n/translations';
import { education, skills } from '../i18n/content';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/paths';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);

const allProjects = await getCollection('projects');
const enProjects = allProjects
  .filter(e => e.id.startsWith('en/') && e.data.featuredOnHome)
  .sort((a, b) => a.data.order - b.data.order);

const homeProjects = enProjects.map(enEntry => {
  const projectId = enEntry.id.replace('en/', '');
  const langEntry = allProjects.find(e => e.id === `${lang}/${projectId}` && e.body?.trim());
  return langEntry ?? enEntry;
});
---

<section class="max-w-4xl mx-auto px-6 pb-24"
         style="border-top: 1px solid var(--color-border);">

  <!-- ── Education ─────────────────────────────────────────────────── -->
  <div class="pt-14 pb-12">
    <h2 class="text-sm tracking-widest uppercase mb-8"
        style="color: var(--color-accent);">
      {tr.resume.education}
    </h2>

    <div class="space-y-8">
      {education.map(edu => (
        <div class="grid md:grid-cols-3 gap-2 md:gap-6">
          <!-- School + degree -->
          <div class="md:col-span-2">
            <p class="text-xl font-medium" style="color: var(--color-text);">
              {edu.school}
            </p>
            <p class="text-base mt-1" style="color: var(--color-muted);">
              {edu.degree[lang]}
            </p>
            {edu.note && (
              <p class="text-sm mt-1 italic" style="color: var(--color-muted);">
                {edu.note[lang]}
              </p>
            )}
          </div>
          <!-- Period + location -->
          <div class="text-sm text-right" style="color: var(--color-muted);">
            <p>{edu.period}</p>
            <p class="text-xs mt-1">{edu.location}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Skills ────────────────────────────────────────────────────── -->
  <div class="py-12" style="border-top: 1px solid var(--color-border);">
    <h2 class="text-sm tracking-widest uppercase mb-8"
        style="color: var(--color-accent);">
      {tr.resume.skills}
    </h2>

    <div class="space-y-4">
      {Object.entries(skills).map(([category, items]) => (
        <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-6">
          <span class="text-sm tracking-widest uppercase w-32 shrink-0"
                style="color: var(--color-muted);">
            {tr.resume.skillCategories[category as keyof typeof tr.resume.skillCategories]}
          </span>
          <div class="flex flex-wrap gap-2">
            {items.map(skill => (
              <span class="text-sm px-3 py-1 border"
                    style="border-color: var(--color-border); color: var(--color-text);">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Projects (summary list) ───────────────────────────────────── -->
  <div class="py-12" style="border-top: 1px solid var(--color-border);">
    <h2 class="text-sm tracking-widest uppercase mb-8"
        style="color: var(--color-accent);">
      {tr.resume.projects}
    </h2>

    <div class="space-y-6">
      {homeProjects.map(project => (
        <div class="flex flex-col md:flex-row md:items-start gap-1 md:gap-6">
          <div class="md:w-64 shrink-0">
            <div class="flex items-center gap-3">
              <a href={withBase(`/${lang}/projects/${project.data.id}`)}
                 class="text-lg font-medium transition-colors duration-200"
                 style="color: var(--color-text); text-decoration: none;"
                 onmouseover="this.style.color='var(--color-accent)'"
                 onmouseout="this.style.color='var(--color-text)'">
                {project.data.title}
              </a>
              {project.data.wip && (
                <span class="text-xs px-2 py-0.5 tracking-wider"
                      style="border: 1px solid var(--color-accent); color: var(--color-accent);">
                  {tr.projects.wip}
                </span>
              )}
            </div>
            {project.data.period && (
              <p class="text-xs tracking-wider uppercase mt-1" style="color: var(--color-muted);">
                {project.data.period}
              </p>
            )}
            <div class="flex flex-wrap gap-1 mt-2">
              {project.data.tags.map(tag => (
                <span class="text-xs px-1.5 py-0.5 tracking-wider"
                      style="background-color: var(--color-border); color: var(--color-muted);">
                  {tag}
                </span>
              ))}
            </div>
          </div>
          <p class="text-base leading-relaxed flex-1" style="color: var(--color-text);">
            {project.data.homeDescription ?? project.data.description}
          </p>
        </div>
      ))}
    </div>

    <!-- Link to full projects page -->
    <div class="mt-10">
      <a href={withBase(`/${lang}/projects`)}
         class="text-sm tracking-wider transition-colors duration-200"
         style="color: var(--color-accent); text-decoration: none;"
         onmouseover="this.style.color='var(--color-text)'"
         onmouseout="this.style.color='var(--color-accent)'">
        {tr.resume.viewAll}
      </a>
    </div>
  </div>

</section>
