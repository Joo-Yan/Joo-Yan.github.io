---
// Accessibility controls: font size toggle + font family toggle
// Collapsible floating panel triggered by an Aa button.
// State is persisted in localStorage and restored by the anti-FOUC script in Layout.astro.
---

<style>
  #a11y-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-muted);
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.05em;
    cursor: pointer;
    border-radius: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  #a11y-toggle:hover {
    color: var(--color-text);
  }
  #a11y-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  #a11y-toggle[aria-expanded="true"] {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  #a11y-panel {
    position: absolute;
    bottom: calc(100% + 8px);
    right: 0;
    min-width: 180px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }

  .a11y-group-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
  }

  .a11y-btn-row {
    display: flex;
    gap: 0.5rem;
  }

  .a11y-btn {
    flex: 1;
    min-height: 44px;
    padding: 0 0.5rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    cursor: pointer;
    border-radius: 2px;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    line-height: 1.3;
  }
  .a11y-btn:hover {
    color: var(--color-text);
  }
  .a11y-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .a11y-btn[aria-pressed="true"] {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
</style>

<div
  id="a11y-controls"
  role="region"
  aria-label="Accessibility options"
  style="
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  "
>
  <!-- Collapsible panel -->
  <div id="a11y-panel" hidden>

    <!-- Font size group -->
    <div role="group" aria-labelledby="a11y-size-label">
      <span id="a11y-size-label" class="a11y-group-label">Text Size</span>
      <div class="a11y-btn-row">
        <button id="btn-size-normal" class="a11y-btn" aria-pressed="true">Normal</button>
        <button id="btn-size-large" class="a11y-btn" aria-pressed="false">Large</button>
      </div>
    </div>

    <!-- Font family group -->
    <div role="group" aria-labelledby="a11y-font-label">
      <span id="a11y-font-label" class="a11y-group-label">Font</span>
      <div class="a11y-btn-row">
        <button id="btn-font-design" class="a11y-btn" aria-pressed="true">Serif</button>
        <button id="btn-font-readable" class="a11y-btn" style="font-family: system-ui, -apple-system, Arial, sans-serif;" aria-pressed="false">Sans</button>
      </div>
    </div>

  </div>

  <!-- Toggle button -->
  <button
    id="a11y-toggle"
    aria-expanded="false"
    aria-controls="a11y-panel"
    aria-label="Accessibility options"
    title="Accessibility options"
  >Aa</button>

</div>

<script>
  (function () {
    var html = document.documentElement;
    var toggle = document.getElementById('a11y-toggle');
    var panel  = document.getElementById('a11y-panel');
    var btnSizeNormal   = document.getElementById('btn-size-normal');
    var btnSizeLarge    = document.getElementById('btn-size-large');
    var btnFontDesign   = document.getElementById('btn-font-design');
    var btnFontReadable = document.getElementById('btn-font-readable');

    // ── Panel open/close ──────────────────────────────────────────────────────
    function openPanel() {
      panel.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
    }
    function closePanel() {
      panel.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
    }
    function togglePanel() {
      if (panel.hidden) { openPanel(); } else { closePanel(); }
    }

    toggle.addEventListener('click', togglePanel);

    // Close on Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !panel.hidden) { closePanel(); toggle.focus(); }
    });

    // Close on outside click
    document.addEventListener('click', function (e) {
      var ctrl = document.getElementById('a11y-controls');
      if (!panel.hidden && ctrl && !ctrl.contains(e.target)) { closePanel(); }
    });

    // ── Button state sync ─────────────────────────────────────────────────────
    function syncSize() {
      var large = html.classList.contains('text-large');
      btnSizeNormal.setAttribute('aria-pressed', large ? 'false' : 'true');
      btnSizeLarge.setAttribute('aria-pressed',  large ? 'true'  : 'false');
    }
    function syncFont() {
      var readable = html.classList.contains('font-readable');
      btnFontDesign.setAttribute('aria-pressed',   readable ? 'false' : 'true');
      btnFontReadable.setAttribute('aria-pressed',  readable ? 'true'  : 'false');
    }

    // ── Button actions ────────────────────────────────────────────────────────
    btnSizeNormal.addEventListener('click', function () {
      html.classList.remove('text-large');
      localStorage.setItem('a11y-size', 'normal');
      syncSize();
    });
    btnSizeLarge.addEventListener('click', function () {
      html.classList.add('text-large');
      localStorage.setItem('a11y-size', 'large');
      syncSize();
    });
    btnFontDesign.addEventListener('click', function () {
      html.classList.remove('font-readable');
      localStorage.setItem('a11y-font', 'design');
      syncFont();
    });
    btnFontReadable.addEventListener('click', function () {
      html.classList.add('font-readable');
      localStorage.setItem('a11y-font', 'readable');
      syncFont();
    });

    // Initialise pressed states to match current html classes (set by anti-FOUC script)
    syncSize();
    syncFont();
  })();
</script>
