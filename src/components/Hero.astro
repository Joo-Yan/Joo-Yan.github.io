---
import { t, type Lang } from '../i18n/translations';
import { withBase } from '../utils/paths';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<section class="max-w-4xl mx-auto px-6 pt-20 sm:pt-32 pb-16 sm:pb-24">
  <div class="fade-up">
    <!-- Name -->
    <h1 class="text-[clamp(2.5rem,10vw,5.5rem)] font-display font-medium leading-[0.9] tracking-tight text-[var(--color-text)]">
      YU,<span class="inline-block translate-x-[-0.05em]">&thinsp;</span>Zhuoyan
    </h1>

    <!-- Simple rule -->
    <div class="mt-8 mb-10 h-px bg-[var(--color-accent)] w-16"></div>
  </div>

  <div class="fade-up fade-up-delay-1 max-w-2xl">
    <!-- Tagline -->
    <p class="text-sm sm:text-base tracking-[0.2em] uppercase mb-4 text-[var(--color-muted)] font-sans">
      {tr.hero.tagline}
    </p>
    <p class="text-lg sm:text-xl leading-relaxed text-[var(--color-muted)] font-serif italic">
      {tr.hero.available}
      {' '}
      <a
        href={withBase(`/${lang}/blog/why-me`)}
        class="text-[var(--color-text)] no-underline border-b border-[var(--color-text)] transition-all duration-300 hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] pb-0.5"
      >
        {tr.hero.whyMe}
      </a>
    </p>
  </div>

  <!-- Social links -->
  <div class="fade-up fade-up-delay-2 flex flex-wrap items-center gap-6 sm:gap-8 mt-12">
    <a href="https://github.com/Joo-Yan"
       target="_blank"
       rel="noopener noreferrer"
       class="group flex items-center gap-2.5 text-sm tracking-[0.1em] uppercase no-underline text-[var(--color-muted)] transition-colors duration-200 hover:text-[var(--color-text)]">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="transition-transform duration-300 group-hover:-translate-y-0.5">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
      </svg>
      GitHub
    </a>

    <span class="text-[var(--color-border)] hidden sm:inline" aria-hidden="true">/</span>

    <a href="mailto:zhuoyanyuu@gmail.com"
       class="group flex items-center gap-2.5 text-sm tracking-[0.1em] uppercase no-underline text-[var(--color-muted)] transition-colors duration-200 hover:text-[var(--color-text)]">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="transition-transform duration-300 group-hover:-translate-y-0.5">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="m2 7 10 7 10-7"/>
      </svg>
      Email
    </a>
  </div>
</section>

