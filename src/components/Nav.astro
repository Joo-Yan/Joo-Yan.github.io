---
import { t, LANGUAGES, type Lang } from '../i18n/translations';
import { withBase } from '../utils/paths';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const tr = t(lang);
const homePath = `/${lang}`;
const currentPagePath = withBase(currentPath);

// Build path for a different language by replacing the language prefix
function langPath(targetLang: Lang): string {
  // e.g. /zh/projects → /en/projects
  return withBase(currentPath.replace(/^\/(zh|en|fr)/, `/${targetLang}`));
}

// Build path for a nav item in the current language
function navPath(page: string): string {
  return withBase(page === 'home' ? homePath : `/${lang}/${page}`);
}

const navItems = [
  { key: 'home', label: tr.nav.home, href: navPath('home'), current: homePath },
  { key: 'projects', label: tr.nav.projects, href: navPath('projects'), current: `/${lang}/projects` },
  { key: 'about', label: tr.nav.about, href: navPath('about'), current: `/${lang}/about` },
  { key: 'blog', label: tr.nav.blog, href: navPath('blog'), current: `/${lang}/blog` },
];

const langLabels: Record<Lang, string> = { zh: '中', en: 'EN', fr: 'FR' };
const enabledLanguages: Lang[] = ['en', 'fr'];
---

<header class="fixed top-0 left-0 right-0 z-50" style="background-color: var(--color-bg);">
  <div style="border-bottom: 1px solid var(--color-border);">
    <nav class="max-w-4xl mx-auto flex items-center justify-between" style="height: 56px; padding-left: 24px; padding-right: 24px;">

      <!-- Logo / Name -->
      <a href={withBase(homePath)}
         style="color: var(--color-text); text-decoration: none; font-family: var(--font-display); font-weight: 400; font-size: 20px; line-height: 1; letter-spacing: 0.15em;">
        Yan
      </a>

      <!-- Desktop: Nav links + language switcher -->
      <div class="hidden sm:flex items-center" style="gap: 32px;">

        <!-- Page links -->
        <ul class="flex items-center list-none m-0 p-0" style="gap: 24px;">
          {navItems.map(item => (
            <li>
              <a href={item.href}
                 class="transition-colors duration-200"
                 style={`color: ${currentPath === item.current || (item.key === 'home' && currentPagePath === item.href) ? 'var(--color-accent)' : 'var(--color-muted)'}; text-decoration: none; font-size: 16px; line-height: 1.2; letter-spacing: 0.08em;`}
                 onmouseover="this.style.color='var(--color-text)'"
                 onmouseout={`this.style.color='${currentPath === item.current || (item.key === 'home' && currentPagePath === item.href) ? 'var(--color-accent)' : 'var(--color-muted)'}'`}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Language switcher -->
        <div class="flex items-center"
             style="gap: 8px; border-left: 1px solid var(--color-border); padding-left: 24px; font-size: 12px; line-height: 1; letter-spacing: 0.12em;">
          {LANGUAGES.map((l, i) => (
            <>
              {i > 0 && <span style="color: var(--color-disabled);">·</span>}
              {!enabledLanguages.includes(l)
                ? <span style="color: var(--color-disabled); cursor: not-allowed;">{langLabels[l]}</span>
                : l === lang
                ? <span style="color: var(--color-accent);">{langLabels[l]}</span>
                : <a href={langPath(l)}
                     style="color: var(--color-muted); text-decoration: none;"
                     onmouseover="this.style.color='var(--color-text)'"
                     onmouseout="this.style.color='var(--color-muted)'">
                     {langLabels[l]}
                   </a>
              }
            </>
          ))}
        </div>

      </div>

      <!-- Mobile: hamburger button -->
      <button id="mobile-menu-btn"
              class="sm:hidden flex flex-col justify-center items-center gap-1.5 w-8 h-8"
              style="background: none; border: none; cursor: pointer; padding: 0;"
              aria-label="Toggle menu">
        <span class="menu-bar block w-5 h-px transition-all duration-200" style="background-color: var(--color-text);"></span>
        <span class="menu-bar block w-5 h-px transition-all duration-200" style="background-color: var(--color-text);"></span>
        <span class="menu-bar block w-5 h-px transition-all duration-200" style="background-color: var(--color-text);"></span>
      </button>

    </nav>
  </div>

  <!-- Mobile menu dropdown -->
  <div id="mobile-menu"
       class="sm:hidden hidden"
       style="background-color: var(--color-bg); border-bottom: 1px solid var(--color-border);">
    <div class="max-w-4xl mx-auto flex flex-col" style="padding: 16px 24px; gap: 16px;">

      <!-- Mobile nav links -->
      {navItems.map(item => (
        <a href={item.href}
           style={`color: ${currentPath === item.current || (item.key === 'home' && currentPagePath === item.href) ? 'var(--color-accent)' : 'var(--color-muted)'}; text-decoration: none; font-size: 16px; line-height: 1.2; letter-spacing: 0.08em;`}>
          {item.label}
        </a>
      ))}

      <!-- Mobile language switcher -->
      <div class="flex items-center"
           style="gap: 8px; padding-top: 8px; border-top: 1px solid var(--color-border); font-size: 12px; line-height: 1; letter-spacing: 0.12em;">
        {LANGUAGES.map((l, i) => (
          <>
            {i > 0 && <span style="color: var(--color-disabled);">·</span>}
            {!enabledLanguages.includes(l)
              ? <span style="color: var(--color-disabled); cursor: not-allowed;">{langLabels[l]}</span>
              : l === lang
              ? <span style="color: var(--color-accent);">{langLabels[l]}</span>
              : <a href={langPath(l)}
                   style="color: var(--color-muted); text-decoration: none;">
                   {langLabels[l]}
                 </a>
            }
          </>
        ))}
      </div>
    </div>
  </div>
</header>

<!-- Spacer so content doesn't hide under fixed nav -->
<div style="height: 56px;"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
