---
import { t, LANGUAGES, type Lang } from '../i18n/translations';
import { withBase } from '../utils/paths';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const tr = t(lang);
const homePath = `/${lang}`;
const currentPagePath = withBase(currentPath);

// Build path for a different language by replacing the language prefix
function langPath(targetLang: Lang): string {
  // e.g. /zh/projects → /en/projects
  return withBase(currentPath.replace(/^\/(zh|en|fr)/, `/${targetLang}`));
}

// Build path for a nav item in the current language
function navPath(page: string): string {
  return withBase(page === 'home' ? homePath : `/${lang}/${page}`);
}

const navItems = [
  { key: 'home', label: tr.nav.home, href: navPath('home'), current: homePath },
  { key: 'projects', label: tr.nav.projects, href: navPath('projects'), current: `/${lang}/projects` },
  { key: 'about', label: tr.nav.about, href: navPath('about'), current: `/${lang}/about` },
  { key: 'blog', label: tr.nav.blog, href: navPath('blog'), current: `/${lang}/blog` },
];

const langLabels: Record<Lang, string> = { zh: '中', en: 'EN', fr: 'FR' };
const enabledLanguages: Lang[] = ['en', 'fr'];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]">
  <div class="border-b border-[var(--color-border)]">
    <nav class="max-w-4xl mx-auto flex items-center justify-between h-14 px-6">

      <!-- Logo / Name -->
      <a href={withBase(homePath)}
         class="text-[var(--color-text)] no-underline font-display font-normal text-xl leading-none tracking-[0.15em] transition-opacity duration-200 hover:opacity-70">
        Yan
      </a>

      <!-- Desktop: Nav links + language switcher -->
      <div class="hidden sm:flex items-center gap-8">

        <!-- Page links -->
        <ul class="flex items-center list-none m-0 p-0 gap-6">
          {navItems.map(item => {
            const isActive = currentPath === item.current || (item.key === 'home' && currentPagePath === item.href);
            return (
              <li>
                <a href={item.href}
                   class={`relative text-base leading-tight tracking-[0.08em] no-underline transition-colors duration-200 group
                           ${isActive ? 'text-[var(--color-accent)]' : 'text-[var(--color-muted)] hover:text-[var(--color-text)]'}`}>
                  {item.label}
                  <span class={`absolute -bottom-1 left-0 w-0 h-px bg-[var(--color-accent)] transition-all duration-300 group-hover:w-full ${isActive ? 'w-full' : ''}`}></span>
                </a>
              </li>
            );
          })}
        </ul>

        <!-- Language switcher -->
        <div class="flex items-center gap-2 border-l border-[var(--color-border)] pl-6 text-xs leading-none tracking-[0.12em]">
          {LANGUAGES.map((l, i) => (
            <>
              {i > 0 && <span class="text-[var(--color-disabled)]">·</span>}
              {!enabledLanguages.includes(l)
                ? <span class="text-[var(--color-disabled)] cursor-not-allowed" aria-hidden="true">{langLabels[l]}</span>
                : l === lang
                ? <span class="text-[var(--color-accent)] font-medium" aria-current="page">{langLabels[l]}</span>
                : <a href={langPath(l)}
                     class="text-[var(--color-muted)] no-underline transition-colors duration-200 hover:text-[var(--color-text)]">
                     {langLabels[l]}
                   </a>
              }
            </>
          ))}
        </div>

      </div>

      <!-- Mobile: hamburger button -->
      <button id="mobile-menu-btn"
              class="sm:hidden flex flex-col justify-center items-center gap-[5px] w-8 h-8 bg-transparent border-none cursor-pointer p-0 z-50 group"
              aria-expanded="false"
              aria-controls="mobile-menu"
              aria-label="Toggle menu">
        <span class="menu-bar block w-5 h-[1.5px] bg-[var(--color-text)] transition-all duration-300 ease-out origin-center group-aria-expanded:rotate-45 group-aria-expanded:translate-y-[6.5px]"></span>
        <span class="menu-bar block w-5 h-[1.5px] bg-[var(--color-text)] transition-all duration-300 ease-out group-aria-expanded:opacity-0 group-aria-expanded:translate-x-2"></span>
        <span class="menu-bar block w-5 h-[1.5px] bg-[var(--color-text)] transition-all duration-300 ease-out origin-center group-aria-expanded:-rotate-45 group-aria-expanded:-translate-y-[6.5px]"></span>
      </button>

    </nav>
  </div>

  <!-- Mobile menu dropdown -->
  <div id="mobile-menu"
       class="sm:hidden grid grid-rows-[0fr] bg-[var(--color-bg)] border-b border-[var(--color-border)] overflow-hidden transition-[grid-template-rows] duration-300 ease-in-out"
       role="navigation">
    <div class="min-h-0 opacity-0 transition-opacity duration-300">
      <div class="max-w-4xl mx-auto flex flex-col p-6 pt-2 gap-4">

        <!-- Mobile nav links -->
        {navItems.map(item => {
          const isActive = currentPath === item.current || (item.key === 'home' && currentPagePath === item.href);
          return (
            <a href={item.href}
               class={`text-base leading-tight tracking-[0.08em] no-underline transition-colors duration-200 py-1
                       ${isActive ? 'text-[var(--color-accent)]' : 'text-[var(--color-muted)]'}`}>
              {item.label}
            </a>
          );
        })}

        <!-- Mobile language switcher -->
        <div class="flex items-center gap-2 pt-4 mt-2 border-t border-[var(--color-border)] text-xs leading-none tracking-[0.12em]">
          {LANGUAGES.map((l, i) => (
            <>
              {i > 0 && <span class="text-[var(--color-disabled)]">·</span>}
              {!enabledLanguages.includes(l)
                ? <span class="text-[var(--color-disabled)] cursor-not-allowed">{langLabels[l]}</span>
                : l === lang
                ? <span class="text-[var(--color-accent)] font-medium">{langLabels[l]}</span>
                : <a href={langPath(l)}
                     class="text-[var(--color-muted)] no-underline">
                     {langLabels[l]}
                   </a>
              }
            </>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Spacer so content doesn't hide under fixed nav -->
<div class="h-14"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuInner = menu?.querySelector('div');

  btn?.addEventListener('click', () => {
    const isExpanded = btn.getAttribute('aria-expanded') === 'true';
    const nextState = !isExpanded;
    
    btn.setAttribute('aria-expanded', String(nextState));
    
    if (nextState) {
      menu?.classList.remove('grid-rows-[0fr]');
      menu?.classList.add('grid-rows-[1fr]');
      if (menuInner) menuInner.style.opacity = '1';
    } else {
      menu?.classList.remove('grid-rows-[1fr]');
      menu?.classList.add('grid-rows-[0fr]');
      if (menuInner) menuInner.style.opacity = '0';
    }
  });

  // Close menu on resize if window becomes larger than sm breakpoint
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 640 && btn?.getAttribute('aria-expanded') === 'true') {
      btn.setAttribute('aria-expanded', 'false');
      menu?.classList.remove('grid-rows-[1fr]');
      menu?.classList.add('grid-rows-[0fr]');
      if (menuInner) menuInner.style.opacity = '0';
    }
  });
</script>

