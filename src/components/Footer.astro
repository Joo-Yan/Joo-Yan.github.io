---
import type { Lang } from '../i18n/translations';
import type { translations } from '../i18n/translations';

interface Props {
  lang: Lang;
  tr: typeof translations[Lang];
}

const { tr } = Astro.props;
---

<footer class="max-w-4xl mx-auto px-6 py-10"
        style="border-top: 1px solid var(--color-border);">
  <div class="flex items-center justify-between">
    <p class="text-xs tracking-wider" style="color: var(--color-muted);">
      YU Zhuoyan
    </p>
    <p class="text-xs tracking-wider" style="color: var(--color-border);">
      {tr.footer.built}
    </p>
  </div>
</footer>
